@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main class="bg-gray-200">
        <div class="flex justify-between gap-x-10 gap-y-5 border-b border-gray-700">
            <h3>System Uptime:
                <UptimeDisplay />
            </h3>
            <NavLink href="/help" class="text-blue-300 hover:text-blue-200">Help</NavLink>
        </div>

        <article class="">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
